# --- DATABASE (Prisma direct connection) ---
# For local dev (default — uses SQLite):
# DATABASE_URL="file:/home/z/my-project/db/custom.db"

# For Supabase PostgreSQL (recommended):
# Replace <password> with your actual Supabase database password
# Note: URL-encode any special characters in the password (@ → %40, # → %23, etc.)
# Use the session-mode pooler (port 5432) — Prisma requires prepared statements
DATABASE_URL="postgresql://postgres.ltbmddnhqcoacqdckwzk:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Optional: direct connection (for migrations, bypasses pooler)
# DIRECT_URL="postgresql://postgres:<password>@db.ltbmddnhqcoacqdckwzk.supabase.co:5432/postgres"

# --- SUPABASE (optional — for realtime / Supabase Auth in Phase 2) ---
NEXT_PUBLIC_SUPABASE_URL="https://ltbmddnhqcoacqdckwzk.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_EmrR2YvglSlooCggOBwAqg_J4P1d_MN"

